# ─── GeoSphere WB+ API Configuration ─────────────────────────────
# Copy this file to .env and customize values

# Server
PORT=4000
NODE_ENV=production

# PostgreSQL / PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=osm_wb
DB_USER=postgres
DB_PASSWORD=

# External Services
OSRM_URL=http://localhost:5000
NOMINATIM_URL=http://localhost:8088
GEOSERVER_URL=http://localhost:8080/geoserver
OPENAQ_API_KEY=
FLICKR_API_KEY=

# GeoServer Workspace
GEOSERVER_WORKSPACE=geosphere_wb

# Authentication
JWT_SECRET=change-me-to-a-strong-random-secret-in-production

# Rate Limiting (requests per 15-minute window)
RATE_LIMIT_MAX=300
